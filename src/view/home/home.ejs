              <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 flex space-x-2 z-10">
                <button class="w-2 h-2 rounded-full bg-white opacity-100" data-photo="0"></button>
                <button class="w-2 h-2 rounded-full bg-white opacity-50 hover:opacity-100 transition" data-photo="1"></button>
                <button class="w-2 h-2 rounded-full bg-white opacity-50 hover:opacity-100 transition" data-photo="2"></button>
                <button class="w-2 h-2 rounded-full bg-white opacity-50 hover:opacity-100 transition" data-photo="3"></button>
              </div>

              <script>
                const photos = [
                  "https://cf.bstatic.com/xdata/images/hotel/max1024x768/786222294.jpg?k=6fe6d8ef463c205fbc0090fa123b1d0fed3452e2ce50d9b6356b104aeab10ec9&o=",
                  "https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?q=80&w=1000&auto=format&fit=crop",
                  "https://images.unsplash.com/photo-1523755231516-e43fd2e8dca5?q=80&w=1000&auto=format&fit=crop",
                  "https://images.unsplash.com/photo-1464983953574-0892a716854b?q=80&w=1000&auto=format&fit=crop",
                ];

                const mainPhoto = document.getElementById('mainPhoto');
                const buttons = document.querySelectorAll('[data-photo]');
                let currentIdx = 0;

                mainPhoto.style.transition = "opacity 0.5s ease";

                function switchPhoto(idx) {
                  mainPhoto.style.opacity = 0;
                  setTimeout(() => {
                  mainPhoto.src = photos[idx];
                  mainPhoto.style.opacity = 1;
                  }, 300);

                  buttons.forEach(b => b.classList.remove('opacity-100'));
                  buttons.forEach(b => b.classList.add('opacity-50'));
                  buttons[idx].classList.remove('opacity-50');
                  buttons[idx].classList.add('opacity-100');
                  currentIdx = idx;
                }

                buttons.forEach((btn, idx) => {
                  btn.addEventListener('click', () => {
                  switchPhoto(idx);
                  });
                });

                document.getElementById('prevPhoto').addEventListener('click', () => {
                  let idx = (currentIdx - 1 + photos.length) % photos.length;
                  switchPhoto(idx);
                });

                document.getElementById('nextPhoto').addEventListener('click', () => {
                  let idx = (currentIdx + 1) % photos.length;
                  switchPhoto(idx);
                });
              </script>
