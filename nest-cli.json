{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {"include": "view/**/*" , "outDir": "dist/"},
      {"include": "public/**/*" , "outDir": "dist/"}
  
  ]
  }
}

